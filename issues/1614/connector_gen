     kafka/bin/kafka-topics.sh --bootstrap-server nj1-4.kafka-1.ext-0:1643,nj1-4.kafka-2.ext-0:1650,nj1-4.kafka-3.ext-0:1657,nj1-4.kafka-4.ext-0:1664  --create  --topic connect-storage-nj1-4.kafkacw-1-status --partitions 5 --replication-factor 3 --config cleanup.policy=compact --config min.compaction.lag.ms=60000
    export KAFKA_HEAP_OPTS="-Xms16G -Xmx16G"
    while :; do
        kafka/bin/connect-distributed.sh -daemon worker.properties
        # Wait up to 30 seconds for port to become available
        timeout 30 bash -c 'until lsof -i :1683 >/dev/null 2>&1; do sleep 1; done'
        if [ $? -eq 0 ]; then
            echo "Connection established on port 1683"
            break
        fi
        pkill -f connect-distributed
        echo "Retrying in 5 seconds..."
        sleep 5
    done
}
