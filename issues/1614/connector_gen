function start_worker {
     kafka/bin/kafka-topics.sh --bootstrap-server nj1-4.kafka-1.ext-0:1643,nj1-4.kafka-2.ext-0:1650,nj1-4.kafka-3.ext-0:1657,nj1-4.kafka-4.ext-0:1664   --create  --topic connect-storage-nj1-4.kafkacw-1-offsets  --partitions 25  --replication-factor 3  --config cleanup.policy=compact  --config min.compaction.lag.ms=60000  --config segment.bytes=1073741824
