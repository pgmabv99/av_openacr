ka-14--nj1-sv3\n  namespace: nj1-4\nspec:\n  nodeName: nj1.sv3\n  dnsPolicy: None\n  dnsConfig:\n    nameservers:\n      - 1.1.1.1\n      - 8.8.8.8\n  hostAliases:\n    - ip: 192.168.10.31\n      hostnames:\n      - nj1.sv3\n  hostname: kafka-14--nj1-sv3\n  hostNetwork: true\n  restartPolicy: Always\n  volumes:\n   - name: dctr\n     hostPath:\n       path: /srv/script/kafka-14\n   - name: localtime\n     hostPath:\n       path: /etc/localtime\n   - name: timezone\n     hostPath:\n       path: /etc/timezone\n   - name: shm\n     emptyDir:\n       medium: Memory\n       sizeLimit: 1Gi\n  containers:\n    - name: kafka-14\n      image: docker.io/library/kafka\n      imagePullPolicy: IfNotPresent\n      securityContext:\n        privileged: true\n#      ports:\n#        - name: port22\n#          containerPort: 1649\n#          hostPort: 1649\n#          hostIP: 192.168.10.31\n#        - name: port9092\n#          containerPort: 1650\n#          hostPort: 1650\n#          hostIP: 192.168.10.31\n#        - name: port9093\n#          containerPort: 1651\n#          hostPort: 1651\n#          hostIP: 192.168.10.31\n#        - name: port9094\n#          containerPort: 1652\n#          hostPort: 1652\n#          hostIP: 192.168.10.31\n#        - name: port9095\n#          containerPort: 1653\n#          hostPort: 1653\n#          hostIP: 192.168.10.31\n#        - name: port9096\n#          containerPort: 1654\n#          hostPort: 1654\n#          hostIP: 192.168.10.31\n#        - name: port9097\n#          containerPort: 1655\n#          hostPort: 1655\n#          hostIP: 192.168.10.31\n      volumeMounts:\n       - name: dctr\n         mountPath: /etc/x2.d/script\n       - name: localtime\n         mountPath: /etc/localtime\n         readOnly: true\n       - name: timezone\n         mountPath: /etc/timezone\n         readOnly: true\n       - name: shm\n         mountPath: /dev/shm\n      tty: true\n      stdin: true\nEOF\nK8NS=$(sudo kubectl get pod -A | awk \'$2=="kafka-14--nj1-sv3"{print $1; exit}\')\n[ -n "$K8NS" ] && sudo kubectl delete pod -n $K8NS kafka-14--nj1-sv3\nsleep 5\nsudo kubectl apply -f $MANIFEST\n\n' -q:Y
