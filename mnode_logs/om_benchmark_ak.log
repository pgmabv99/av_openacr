verbose: bin/x2node  -node:nj1.sn2.bm -cmd:$'#!/bin/bash\n# Generated by dkr\nmkdir -p /srv/script/kafka-13\nchmod g+w /srv/script/kafka-13\ntouch  /srv/script/kafka-13/kafka-13.start\nchmod ugo+wx  /srv/script/kafka-13/kafka-13.start\nln -sfr /srv/script/kafka-13/kafka-13.start /srv/script/kafka-13/start\ntee >/srv/script/kafka-13/kafka-13.start << \'EOFSCRIPT\'\n#\n# Script docker/kafka/kafka.start for kafka-13\n#\n# Replaced run.port22:1642\n#!/bin/bash\n# set up kafkausr if not present\n# set softlinks to kafka\nset -e\nUSR="kafkausr"\nUD="1101"\n\nid "$USR" &>/dev/null || usradd -u "$UD" -m -s /bin/bash "$USR"\nhome=$(getent passwd "$USR" | cut -d: -f6)\nln -sfn /opt/kafka/current "$home/kafka"\nln -sfn /opt/kafka/prometheus/current.jar "$home/jmx_prometheus_javaagent.jar"\nls -l "$home/kafka" "$home/jmx_prometheus_javaagent.jar"\nchown -h "$USR:$USR" "$home/kafka" "$home/jmx_prometheus_javaagent.jar"\nchown -R "$USR:$USR" "/opt/kafka"\n\n# mount dirs based on the labels\nfor i in {1..4}; do\n  dir="/mnt/data-${i}"\n  sudo mkdir -p "$dir"\n  if sudo mount -t xfs -o defaults,noatime,nodiscard -L "kafka-data-${i}" "$dir"; then\n    # Only chown if mount succeeded\n    sudo chown kafkausr:kafkausr "$dir"\n  else\n    echo "❌ Mount failed for $dir. Cleaning up..."\n    sudo umount "$dir" 2>/dev/null || true\n    sudo rmdir "$dir"\n  fi\ndone\n\n# Rsyslog\nsed -i \'s/#Port 22/Port 1642/\' /etc/ssh/sshd_config\nservice ssh restart\nsed -i \'/imklog/s/^/#/\' /etc/rsyslog.conf\nrsyslogd\necho \'kafkausr soft nofile 999999\' | sudo tee -a /etc/security/limits.conf\necho \'kafkausr hard nofile 999999\' | sudo tee -a /etc/security/limits.conf\nsleep infinity\n\nEOFSCRIPT\n#\n# Script docker/kafka/kafka.run for kafka-13\n#\nmkdir -p $HOME/k8manifest\nMANIFEST=$HOME/k8manifest/kafka-13--nj1-sv2\nsudo mkdir -p /etc/kubernetes/manifests\nMANIFEST_KUBELET=/etc/kubernetes/manifests/kafka-13--nj1-sv2\ncat > "$MANIFEST" <<\'EOF\'\napiVersion: v1\nkind: Pod\nmetadata:\n  name: kafka-13--nj1-sv2\n  namespace: nj1-4\nspec:\n  nodeName: nj1.sv2\n  dnsPolicy: None\n  dnsConfig:\n    nameservers:\n      - 1.1.1.1\n      - 8.8.8.8\n  hostAliases:\n    - ip: 192.168.10.21\n      hostnames:\n      - nj1.sv2\n  hostname: kafka-13--nj1-sv2\n  hostNetwork: true\n  restartPolicy: Always\n  volumes:\n   - name: dctr\n     hostPath:\n       path: /srv/script/kafka-13\n   - name: localtime\n     hostPath:\n       path: /etc/localtime\n   - name: timezone\n     hostPath:\n       path: /etc/timezone\n   - name: shm\n     emptyDir:\n       medium: Memory\n       sizeLimit: 1Gi\n  containers:\n    - name: kafka-13\n      image: docker.io/library/kafka\n      imagePullPolicy: IfNotPresent\n      securityContext:\n        privileged: true\n#      ports:\n#        - name: port22\n#          containerPort: 1642\n#          hostPort: 1642\n#          hostIP: 192.168.10.21\n#        - name: port9092\n#          containerPort: 1643\n#          hostPort: 1643\n#          hostIP: 192.168.10.21\n#        - name: port9093\n#          containerPort: 1644\n#          hostPort: 1644\n#          hostIP: 192.168.10.21\n#        - name: port9094\n#          containerPort: 1645\n#          hostPort: 1645\n#          hostIP: 192.168.10.21\n#        - name: port9095\n#          containerPort: 1646\n#          hostPort: 1646\n#          hostIP: 192.168.10.21\n#        - name: port9096\n#          containerPort: 1647\n#          hostPort: 1647\n#          hostIP: 192.168.10.21\n#        - name: port9097\n#          containerPort: 1648\n#          hostPort: 1648\n#          hostIP: 192.168.10.21\n      volumeMounts:\n       - name: dctr\n         mountPath: /etc/x2.d/script\n       - name: localtime\n         mountPath: /etc/localtime\n         readOnly: true\n       - name: timezone\n         mountPath: /etc/timezone\n         readOnly: true\n       - name: shm\n         mountPath: /dev/shm\n      tty: true\n      stdin: true\nEOF\nK8NS=$(sudo kubectl get pod -A | awk \'$2=="kafka-13--nj1-sv2"{print $1; exit}\')\n[ -n "$K8NS" ] && sudo kubectl delete pod -n $K8NS kafka-13--nj1-sv2\nsleep 5\nsudo kubectl apply -f $MANIFEST\n\n' -q:Y
