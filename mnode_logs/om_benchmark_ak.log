 name: port8080\n          containerPort: 8080\n          hostPort: 1494\n          hostIP: 192.168.10.11\n      volumeMounts:\n       - name: dctr\n         mountPath: /etc/x2.d/script\n       - name: localtime\n         mountPath: /etc/localtime\n         readOnly: true\n       - name: timezone\n         mountPath: /etc/timezone\n         readOnly: true\n       - name: shm\n         mountPath: /dev/shm\n      tty: true\n      stdin: true\nEOF\nK8NS=$(sudo kubectl get pod -A | awk \'$2=="rdpui-5--nj1-sv1"{print $1; exit}\')\n[ -n "$K8NS" ] && sudo kubectl delete pod -n $K8NS rdpui-5--nj1-sv1\nsleep 5\nsudo kubectl apply -f $MANIFEST\n\n' -q:Y
