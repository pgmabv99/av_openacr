ka-13--nj1-sv2\n  namespace: nj1-4\nspec:\n  nodeName: nj1.sv2\n  dnsPolicy: None\n  dnsConfig:\n    nameservers:\n      - 1.1.1.1\n      - 8.8.8.8\n  hostAliases:\n    - ip: 192.168.10.21\n      hostnames:\n      - nj1.sv2\n  hostname: kafka-13--nj1-sv2\n  hostNetwork: true\n  restartPolicy: Always\n  volumes:\n   - name: dctr\n     hostPath:\n       path: /srv/script/kafka-13\n   - name: localtime\n     hostPath:\n       path: /etc/localtime\n   - name: timezone\n     hostPath:\n       path: /etc/timezone\n   - name: shm\n     emptyDir:\n       medium: Memory\n       sizeLimit: 1Gi\n  containers:\n    - name: kafka-13\n      image: docker.io/library/kafka\n      imagePullPolicy: IfNotPresent\n      securityContext:\n        privileged: true\n#      ports:\n#        - name: port22\n#          containerPort: 1642\n#          hostPort: 1642\n#          hostIP: 192.168.10.21\n#        - name: port9092\n#          containerPort: 1643\n#          hostPort: 1643\n#          hostIP: 192.168.10.21\n#        - name: port9093\n#          containerPort: 1644\n#          hostPort: 1644\n#          hostIP: 192.168.10.21\n#        - name: port9094\n#          containerPort: 1645\n#          hostPort: 1645\n#          hostIP: 192.168.10.21\n#        - name: port9095\n#          containerPort: 1646\n#          hostPort: 1646\n#          hostIP: 192.168.10.21\n#        - name: port9096\n#          containerPort: 1647\n#          hostPort: 1647\n#          hostIP: 192.168.10.21\n#        - name: port9097\n#          containerPort: 1648\n#          hostPort: 1648\n#          hostIP: 192.168.10.21\n      volumeMounts:\n       - name: dctr\n         mountPath: /etc/x2.d/script\n       - name: localtime\n         mountPath: /etc/localtime\n         readOnly: true\n       - name: timezone\n         mountPath: /etc/timezone\n         readOnly: true\n       - name: shm\n         mountPath: /dev/shm\n      tty: true\n      stdin: true\nEOF\nK8NS=$(sudo kubectl get pod -A | awk \'$2=="kafka-13--nj1-sv2"{print $1; exit}\')\n[ -n "$K8NS" ] && sudo kubectl delete pod -n $K8NS kafka-13--nj1-sv2\nsleep 5\nsudo kubectl apply -f $MANIFEST\n\n' -q:Y
