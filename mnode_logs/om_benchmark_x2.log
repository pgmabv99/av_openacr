/script/kafkacw-02\n   - name: localtime\n     hostPath:\n       path: /etc/localtime\n   - name: timezone\n     hostPath:\n       path: /etc/timezone\n   - name: shm\n     emptyDir:\n       medium: Memory\n       sizeLimit: 1Gi\n  containers:\n    - name: kafkacw-02\n      image: docker.io/library/kafkacw\n      imagePullPolicy: IfNotPresent\n      securityContext:\n        privileged: true\n#      ports:\n#        - name: port22\n#          containerPort: 1682\n#          hostPort: 1682\n#          hostIP: 192.168.10.11\n#        - name: port8083\n#          containerPort: 8083\n#          hostPort: 1683\n#          hostIP: 192.168.10.11\n#        - name: port8181\n#          containerPort: 8181\n#          hostPort: 1690\n#          hostIP: 192.168.10.11\n      volumeMounts:\n       - name: dctr\n         mountPath: /etc/x2.d/script\n       - name: localtime\n         mountPath: /etc/localtime\n         readOnly: true\n       - name: timezone\n         mountPath: /etc/timezone\n         readOnly: true\n       - name: shm\n         mountPath: /dev/shm\n      tty: true\n      stdin: true\nEOF\nK8NS=$(sudo kubectl get pod -A | awk \'$2=="kafkacw-02--nj1-sv1"{print $1; exit}\')\n[ -n "$K8NS" ] && sudo kubectl delete pod -n $K8NS kafkacw-02--nj1-sv1\nsleep 5\nsudo kubectl apply -f $MANIFEST\n\n' -q:Y
