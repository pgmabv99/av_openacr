ir:\n       medium: Memory\n       sizeLimit: 1Gi\n  containers:\n    - name: x2-17\n      image: docker.io/library/x2\n      imagePullPolicy: IfNotPresent\n      securityContext:\n        privileged: true\n#      ports:\n#        - name: port1883\n#          containerPort: 1510\n#          hostPort: 1510\n#          hostIP: 192.168.10.21\n#        - name: port2080\n#          containerPort: 1511\n#          hostPort: 1511\n#          hostIP: 192.168.10.21\n#        - name: port22\n#          containerPort: 1512\n#          hostPort: 1512\n#          hostIP: 192.168.10.21\n#        - name: port4222\n#          containerPort: 1513\n#          hostPort: 1513\n#          hostIP: 192.168.10.21\n#        - name: port4223\n#          containerPort: 1514\n#          hostPort: 1514\n#          hostIP: 192.168.10.21\n#        - name: port443\n#          containerPort: 1515\n#          hostPort: 1515\n#          hostIP: 192.168.10.21\n#        - name: port6379\n#          containerPort: 1516\n#          hostPort: 1516\n#          hostIP: 192.168.10.21\n#        - name: port6380\n#          containerPort: 1517\n#          hostPort: 1517\n#          hostIP: 192.168.10.21\n#        - name: port8850\n#          containerPort: 1508\n#          hostPort: 1508\n#          hostIP: 192.168.10.21\n#        - name: port8851\n#          containerPort: 1509\n#          hostPort: 1509\n#          hostIP: 192.168.10.21\n#        - name: port8883\n#          containerPort: 1518\n#          hostPort: 1518\n#          hostIP: 192.168.10.21\n#        - name: port9092\n#          containerPort: 1519\n#          hostPort: 1519\n#          hostIP: 192.168.10.21\n#        - name: port9093\n#          containerPort: 1520\n#          hostPort: 1520\n#          hostIP: 192.168.10.21\n#        - name: portrange\n#          containerPort: 37000-37999\n#          hostPort: 37000-37999\n#          hostIP: 192.168.10.21\n      volumeMounts:\n       - name: dctr\n         mountPath: /etc/x2.d/script\n      