ountPath: /etc/timezone\n         readOnly: true\n       - name: shm\n         mountPath: /dev/shm\n      tty: true\n      stdin: true\nEOF\nK8NS=$(sudo kubectl get pod -A | awk \'$2=="kafkaui-5--nj1-sv1"{print $1; exit}\')\n[ -n "$K8NS" ] && sudo kubectl delete pod -n $K8NS kafkaui-5--nj1-sv1\nsleep 5\nsudo kubectl apply -f $MANIFEST\n\n' -q:Y
