verbose: bin/x2node  -node:nj1.sn1.bm -cmd:$'#!/bin/bash\n# Generated by dkr\nmkdir -p /srv/script/kafkacw-02\nchmod g+w /srv/script/kafkacw-02\ntouch  /srv/script/kafkacw-02/kafkacw-02.start\nchmod ugo+wx  /srv/script/kafkacw-02/kafkacw-02.start\nln -sfr /srv/script/kafkacw-02/kafkacw-02.start /srv/script/kafkacw-02/start\ntee >/srv/script/kafkacw-02/kafkacw-02.start << \'EOFSCRIPT\'\n#\n# Script docker/kafkacw/kafkacw.start for kafkacw-02\n#\n# Replaced run.port22:1682\n#!/bin/bash\n# Rsyslog\n set -e\nsed -i \'s/#Port 22/Port 1682/\' /etc/ssh/sshd_config\nservice ssh restart\n\nUSR="kafkausr"\nUD="1101"\n\nid "$USR" &>/dev/null || usradd -u "$UD" -m -s /bin/bash "$USR"\nhome=$(getent passwd "$USR" | cut -d: -f6)\nln -sfn /opt/kafka/current "$home/kafka"\nln -sfn /opt/kafka/prometheus/current.jar "$home/jmx_prometheus_javaagent.jar"\nls -l "$home/kafka" "$home/jmx_prometheus_javaagent.jar"\nchown -h "$USR:$USR" "$home/kafka" "$home/jmx_prometheus_javaagent.jar"\n\nln -sfn /opt/kafka/plugins "$home/kafka/plugins"\nchown -h "$USR:$USR" "$home/kafka/plugins"\n\nsed -i \'/imklog/s/^/#/\' /etc/rsyslog.conf\nrsyslogd\necho \'kafkausr soft nofile 999999\' | sudo tee -a /etc/security/limits.conf\necho \'kafkausr hard nofile 999999\' | sudo tee -a /etc/security/limits.conf\nsleep infinity\n\nEOFSCRIPT\n#\n# Script docker/kafkacw/kafkacw.run for kafkacw-02\n#\nmkdir -p $HOME/k8manifest\nMANIFEST=$HOME/k8manifest/kafkacw-02--nj1-sv1\nsudo mkdir -p /etc/kubernetes/manifests\nMANIFEST_KUBELET=/etc/kubernetes/manifests/kafkacw-02--nj1-sv1\ncat > "$MANIFEST" <<\'EOF\'\napiVersion: v1\nkind: Pod\nmetadata:\n  name: kafkacw-02--nj1-sv1\n  namespace: nj1-4\nspec:\n  nodeName: nj1.sv1\n  dnsPolicy: None\n  dnsConfig:\n    nameservers:\n      - 1.1.1.1\n      - 8.8.8.8\n  hostAliases:\n    - ip: 192.168.10.11\n      hostnames:\n      - nj1.sv1\n  hostname: kafkacw-02--nj1-sv1\n  hostNetwork: true\n  restartPolicy: Always\n  volumes:\n   - name: dctr\n     hostPath:\n       path: /srv/script/kafkacw-02\n   - name: localtime\n     hostPath:\n       path: /etc/localtime\n   - name: timezone\n     hostPath:\n       path: /etc/timezone\n   - name: shm\n     emptyDir:\n       medium: Memory\n       sizeLimit: 1Gi\n  containers:\n    - name: kafkacw-02\n      image: docker.io/library/kafkacw\n      imagePullPolicy: IfNotPresent\n      securityContext:\n        privileged: true\n#      ports:\n#        - name: port22\n#          containerPort: 1682\n#          hostPort: 1682\n#          hostIP: 192.168.10.11\n#        - name: port8083\n#          containerPort: 8083\n#          hostPort: 1683\n#          hostIP: 192.168.10.11\n#        - name: port8181\n#          containerPort: 8181\n#          hostPort: 1690\n#          hostIP: 192.168.10.11\n      volumeMounts:\n       - name: dctr\n         mountPath: /etc/x2.d/script\n       - name: localtime\n         mountPath: /etc/localtime\n         readOnly: true\n       - name: timezone\n         mountPath: /etc/timezone\n         readOnly: true\n       - name: shm\n         mountPath: /dev/shm\n      tty: true\n      stdin: true\nEOF\nK8NS=$(sudo kubectl get pod -A | awk \'$2=="kafkacw-02--nj1-sv1"{print $1; exit}\')\n[ -n "$K8NS" ] && sudo kubectl delete pod -n $K8NS kafkacw-02--nj1-sv1\nsleep 5\nsudo kubectl apply -f $MANIFEST\n\n' -q:Y
